---
import '../styles/global.css';
import { seo, pageSeo, profile } from '../data/profile';

interface Props {
  title?: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  page?: 'home' | 'projects' | 'about';
}

const { 
  title, 
  description, 
  ogTitle, 
  ogDescription,
  page = 'home' 
} = Astro.props;

// 获取页面级 SEO 配置
const pageConfig = pageSeo[page] || pageSeo.home;

// 最终使用的值
const pageTitle = title || pageConfig.title;
const pageDesc = description || pageConfig.description;
const pageOgTitle = ogTitle || pageConfig.ogTitle;
const pageOgDesc = ogDescription || pageConfig.ogDescription;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDesc} />
    <meta name="author" content={profile.name} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={pageOgTitle} />
    <meta property="og:description" content={pageOgDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={seo.siteName} />
    <meta property="og:image" content={seo.siteUrl + seo.ogImage} />
    <meta property="og:url" content={seo.siteUrl} />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageOgTitle} />
    <meta name="twitter:description" content={pageOgDesc} />
    <meta name="twitter:image" content={seo.siteUrl + seo.ogImage} />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={seo.siteUrl} />
    
    <title>{pageTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Header -->
    <header class="border-b border-gray-800">
      <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-xl font-bold" style="color: var(--color-accent)">{profile.name}</a>
        <div class="flex gap-6">
          <a href="/" class="hover:text-[var(--color-accent)] transition-colors">首页</a>
          <a href="/projects" class="hover:text-[var(--color-accent)] transition-colors">项目</a>
          <a href="/research" class="hover:text-[var(--color-accent)] transition-colors">研究</a>
          <a href="/about" class="hover:text-[var(--color-accent)] transition-colors">关于</a>
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-800 mt-16">
      <div class="max-w-5xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-gray-500 text-sm">© 2026 {profile.name}. Built with Astro.</p>
        <div class="flex gap-4">
          {profile.social.github && (
            <a href={profile.social.github} target="_blank" class="text-gray-400 hover:text-[var(--color-accent)] transition-colors">GitHub</a>
          )}
          {profile.social.bilibili && (
            <a href={profile.social.bilibili} target="_blank" class="text-gray-400 hover:text-[var(--color-accent)] transition-colors">B站</a>
          )}
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
  }
</style>
