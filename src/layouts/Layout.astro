---
import '../styles/global.css';
import { seo, pageSeo, profile } from '../data/profile';

interface Props {
  title?: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  page?: 'home' | 'projects' | 'about' | 'research';
  canonical?: string;
}

const { 
  title, 
  description, 
  ogTitle, 
  ogDescription,
  page = 'home',
  canonical
} = Astro.props;

// 获取页面级 SEO 配置
const pageConfig = pageSeo[page] || pageSeo.home;

// 最终使用的值
const pageTitle = title || pageConfig.title;
const pageDesc = description || pageConfig.description;
const pageOgTitle = ogTitle || pageConfig.ogTitle;
const pageOgDesc = ogDescription || pageConfig.ogDescription;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="zh-CN" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDesc} />
    <meta name="author" content={profile.name} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={pageOgTitle} />
    <meta property="og:description" content={pageOgDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={seo.siteName} />
    <meta property="og:image" content={seo.siteUrl + seo.ogImage} />
    <meta property="og:url" content={seo.siteUrl} />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageOgTitle} />
    <meta name="twitter:description" content={pageOgDesc} />
    <meta name="twitter:image" content={seo.siteUrl + seo.ogImage} />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonical || seo.siteUrl} />
    
    <title>{pageTitle}</title>
    
    <!-- Theme Script (Early Execution to prevent FOUC) -->
    <script is:inline>
      (function() {
        try {
          var localTheme = localStorage.getItem('theme');
          var theme = localTheme || (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
          if (theme === 'light') {
            document.documentElement.classList.add('light-mode');
            document.body.classList.add('light-mode');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col selection:bg-accent/30 selection:text-current relative">
    <!-- Cursor Glow -->
    <div id="cursor-glow" class="pointer-events-none fixed inset-0 z-[-1] transition-opacity duration-300 opacity-0"></div>

    <!-- Header -->
    <header class="fixed top-4 inset-x-0 z-50 flex justify-center px-2 sm:px-4 pointer-events-none">
      <nav class="pointer-events-auto flex items-center p-1 sm:p-1.5 bg-card/40 backdrop-blur-2xl border border-white/10 rounded-[2rem] shadow-[0_8px_32px_rgba(0,0,0,0.4)] transition-all duration-500 hover:bg-card/60">
        <a href="/" class="hidden sm:flex items-center text-lg font-bold text-gradient tracking-wider px-4 border-r border-white/10 mr-1 hover:opacity-80 transition-opacity">
          Garfield
        </a>
        
        <div class="flex items-center gap-0.5 sm:gap-1 text-sm font-medium">
          <a href="/" class={`relative px-3 py-2 sm:px-4 sm:py-2 rounded-full whitespace-nowrap transition-all duration-300 ${currentPath === '/' ? 'text-white bg-white/10 shadow-[inset_0_1px_0_rgba(255,255,255,0.2)]' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}>首页</a>
          <a href="/projects" class={`relative px-3 py-2 sm:px-4 sm:py-2 rounded-full whitespace-nowrap transition-all duration-300 ${currentPath.startsWith('/projects') ? 'text-white bg-white/10 shadow-[inset_0_1px_0_rgba(255,255,255,0.2)]' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}>项目</a>
          <a href="/research" class={`relative px-3 py-2 sm:px-4 sm:py-2 rounded-full whitespace-nowrap transition-all duration-300 ${currentPath.startsWith('/research') ? 'text-white bg-white/10 shadow-[inset_0_1px_0_rgba(255,255,255,0.2)]' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}>研究</a>
          <a href="/about" class={`relative px-3 py-2 sm:px-4 sm:py-2 rounded-full whitespace-nowrap transition-all duration-300 ${currentPath.startsWith('/about') ? 'text-white bg-white/10 shadow-[inset_0_1px_0_rgba(255,255,255,0.2)]' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}>关于</a>
        </div>
        
        <div class="pl-1 ml-1 sm:pl-2 sm:ml-2 border-l border-white/10">
          <!-- Theme Toggle Button -->
          <button id="theme-toggle" class="p-2 sm:p-2.5 rounded-full bg-transparent hover:bg-white/10 hover:scale-110 active:scale-95 transition-all text-sm" aria-label="切换主题">
            <span class="dark-icon block">🌙</span>
            <span class="light-icon hidden">☀️</span>
          </button>
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main class="flex-1 relative z-10">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-white/5 mt-16 bg-card/30 relative z-10 transition-colors duration-500">
      <div class="max-w-5xl mx-auto px-6 py-10 flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-gray-500 text-sm select-none">
          © <span id="easter-egg-trigger" class="cursor-default hover:text-accent transition-colors" title="Maybe tap me?">2026</span> {profile.name}.
        </p>
        <div class="flex gap-4">
          {profile.social.github && (
            <a href={profile.social.github} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-accent transition-colors">GitHub</a>
          )}
          {profile.social.bilibili && (
            <a href={profile.social.bilibili} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-accent transition-colors">bilibili</a>
          )}
          {profile.social.csdn && (
            <a href={profile.social.csdn} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-accent transition-colors">CSDN</a>
          )}
        </div>
      </div>
    </footer>

    <!-- Easter Egg Game Modal -->
    <div id="game-modal" class="fixed inset-0 z-[100] opacity-0 pointer-events-none transition-all duration-500 bg-dark/95 backdrop-blur-2xl flex flex-col overflow-hidden">
      <!-- Animated Background Elements -->
      <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
        <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-accent/20 rounded-full blur-[100px] animate-pulse"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-purple/20 rounded-full blur-[100px] animate-[pulse_4s_ease-in-out_infinite]"></div>
        <!-- Cyber grid -->
        <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:40px_40px] [transform:perspective(1000px)_rotateX(60deg)_translateY(-100px)_translateZ(-200px)] opacity-30"></div>
      </div>

      <div class="relative z-10 flex items-center justify-between px-6 py-4 border-b border-white/10 bg-card/60 backdrop-blur-md shadow-[0_4px_30px_rgba(0,0,0,0.5)]">
        <div class="flex items-center gap-4">
          <div class="relative flex items-center justify-center w-10 h-10 rounded-xl bg-accent/10 border border-accent/30 overflow-hidden group">
            <div class="absolute inset-0 bg-accent/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
            <span class="text-2xl animate-[spin_4s_linear_infinite] relative z-10">🕹️</span>
          </div>
          <div>
            <h3 id="game-title" class="text-white font-bold text-lg tracking-wide uppercase" style="text-shadow: 0 0 10px rgba(0,212,255,0.5);">Loading...</h3>
            <div class="flex items-center gap-2 mt-0.5">
              <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse shadow-[0_0_8px_rgba(74,222,128,0.8)]"></span>
              <p class="text-accent text-xs font-mono tracking-widest">SYSTEM_UNLOCKED</p>
            </div>
          </div>
        </div>
        <div class="flex items-center gap-3 sm:gap-4">
          <button id="btn-next-game" class="group relative px-4 py-2 bg-transparent overflow-hidden rounded-lg border border-white/20 transition-all hover:border-accent/50 focus:outline-none focus:ring-2 focus:ring-accent/50">
            <div class="absolute inset-0 bg-gradient-to-r from-accent/20 to-purple/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
            <div class="relative flex items-center gap-2 text-sm font-medium text-gray-300 group-hover:text-white">
              <span class="group-hover:rotate-180 transition-transform duration-500">🔄</span> 
              <span class="hidden sm:inline">换一个</span>
            </div>
          </button>
          <button id="btn-close-game" class="p-2 text-gray-400 hover:text-white bg-white/5 hover:bg-red-500/20 hover:border-red-500/50 border border-transparent rounded-lg transition-all focus:outline-none focus:ring-2 focus:ring-red-500/50" aria-label="退出系统">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>

      <div class="flex-1 w-full h-full relative z-10 flex items-center justify-center p-4 sm:p-8 perspective-1000">
        <!-- Arcade Cabinet Style Container -->
        <div class="w-full h-full max-w-5xl max-h-[800px] bg-black rounded-xl sm:rounded-2xl border-4 border-gray-800 shadow-[0_0_50px_rgba(0,212,255,0.2),inset_0_0_20px_rgba(0,0,0,1)] overflow-hidden relative transform transition-transform duration-700 hover:scale-[1.01]">
          <!-- Scanline Overlay for retro effect -->
          <div class="absolute inset-0 pointer-events-none z-20 opacity-10 bg-[linear-gradient(rgba(18,16,16,0)_50%,rgba(0,0,0,0.25)_50%),linear-gradient(90deg,rgba(255,0,0,0.06),rgba(0,255,0,0.02),rgba(0,0,255,0.06))] bg-[length:100%_4px,3px_100%]"></div>
          <!-- CRT Screen Glare -->
          <div class="absolute inset-0 pointer-events-none z-20 bg-[radial-gradient(circle_at_center,transparent_50%,rgba(0,0,0,0.4)_100%)]"></div>
          
          <div id="game-loading" class="absolute inset-0 flex items-center justify-center bg-card z-30 transition-opacity duration-500">
            <div class="flex flex-col items-center gap-6">
              <div class="relative w-16 h-16">
                <div class="absolute inset-0 border-4 border-gray-700 rounded-full"></div>
                <div class="absolute inset-0 border-4 border-accent border-t-transparent border-r-transparent rounded-full animate-spin"></div>
                <div class="absolute inset-2 border-4 border-purple border-b-transparent border-l-transparent rounded-full animate-[spin_1.5s_linear_infinite_reverse]"></div>
              </div>
              <div class="text-center">
                <p class="text-accent font-mono text-lg animate-pulse tracking-widest mb-1">BOOTING_ROM...</p>
                <p class="text-gray-500 font-mono text-xs">PLEASE WAIT</p>
              </div>
            </div>
          </div>
          
          <iframe id="game-frame" src="" class="w-full h-full border-0 bg-gray-900 relative z-10" sandbox="allow-scripts allow-same-origin" title="Easter Egg Game"></iframe>
        </div>
      </div>
    </div>

    <script>
      import { easterEggGames, getRandomGame } from '../data/games';

      // Easter Egg Logic
      let clickCount = 0;
      let clickTimer: ReturnType<typeof setTimeout>;
      const REQUIRED_CLICKS = 5;
      const CLICK_TIMEOUT = 2000; // 2 seconds to complete the clicks
      
      const KONAMI_CODE = ['ArrowUp', 'ArrowUp', 'ArrowDown', 'ArrowDown', 'ArrowLeft', 'ArrowRight', 'ArrowLeft', 'ArrowRight', 'b', 'a'];
      const ALTERNATE_CODE = ['g', 'a', 'm', 'e'];
      let keySequence: string[] = [];

      const modal = document.getElementById('game-modal');
      const frame = document.getElementById('game-frame') as HTMLIFrameElement;
      const titleEl = document.getElementById('game-title');
      const loadingScreen = document.getElementById('game-loading');
      
      function launchGame(gameData?: import('../data/games').Game) {
        if (!modal || !frame || !titleEl || !loadingScreen) return;
        
        const isMobile = window.innerWidth <= 768 || 'ontouchstart' in window;
        const game = gameData || getRandomGame(isMobile);
        
        // Show modal
        document.body.style.overflow = 'hidden'; // Prevent background scrolling
        modal.classList.remove('opacity-0', 'pointer-events-none');
        
        // Update UI
        titleEl.textContent = game.name;
        loadingScreen.style.opacity = '1';
        
        // Load game
        frame.src = game.path;
        
        // Hide loading when iframe loads
        frame.onload = () => {
          setTimeout(() => {
            loadingScreen.style.opacity = '0';
            frame.focus();
          }, 500);
        };
      }

      function closeGame() {
        if (!modal || !frame) return;
        document.body.style.overflow = '';
        modal.classList.add('opacity-0', 'pointer-events-none');
        setTimeout(() => {
          frame.src = ''; // Unload iframe to save memory/stop audio
        }, 500);
      }

      // 1. Mouse Click Trigger
      const triggerBtn = document.getElementById('easter-egg-trigger');
      triggerBtn?.addEventListener('click', () => {
        clickCount++;
        clearTimeout(clickTimer);
        
        // Visual feedback
        triggerBtn.style.transform = `scale(${1 + clickCount * 0.1})`;
        triggerBtn.style.color = 'var(--color-accent)';
        
        if (clickCount >= REQUIRED_CLICKS) {
          clickCount = 0;
          triggerBtn.style.transform = 'scale(1)';
          launchGame();
        } else {
          clickTimer = setTimeout(() => {
            clickCount = 0;
            triggerBtn.style.transform = 'scale(1)';
            triggerBtn.style.color = '';
          }, CLICK_TIMEOUT);
        }
      });

      // 2. Keyboard Trigger
      document.addEventListener('keydown', (e) => {
        // Don't capture keys if user is typing in an input
        if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
        
        // Escape closes game
        if (e.key === 'Escape' && !modal?.classList.contains('opacity-0')) {
          closeGame();
          return;
        }

        keySequence.push(e.key);
        // Keep array to max length needed
        if (keySequence.length > Math.max(KONAMI_CODE.length, ALTERNATE_CODE.length)) {
          keySequence.shift();
        }

        const sequenceStr = keySequence.join(',').toLowerCase();
        const konamiStr = KONAMI_CODE.join(',').toLowerCase();
        const altStr = ALTERNATE_CODE.join(',').toLowerCase();

        if (sequenceStr.includes(konamiStr) || sequenceStr.includes(altStr)) {
          keySequence = []; // Reset
          launchGame();
        }
      });

      // Modal Controls
      document.getElementById('btn-close-game')?.addEventListener('click', closeGame);
      document.getElementById('btn-next-game')?.addEventListener('click', () => launchGame());

      // Theme Toggle Logic
      const themeToggle = document.getElementById('theme-toggle');
      const darkIcon = themeToggle?.querySelector('.dark-icon');
      const lightIcon = themeToggle?.querySelector('.light-icon');

      function updateThemeUI(isLight) {
        if (isLight) {
          document.body.classList.add('light-mode');
          document.documentElement.classList.add('light-mode');
          darkIcon?.classList.add('hidden');
          darkIcon?.classList.remove('block');
          lightIcon?.classList.remove('hidden');
          lightIcon?.classList.add('block');
        } else {
          document.body.classList.remove('light-mode');
          document.documentElement.classList.remove('light-mode');
          lightIcon?.classList.add('hidden');
          lightIcon?.classList.remove('block');
          darkIcon?.classList.remove('hidden');
          darkIcon?.classList.add('block');
        }
      }

      // Initialize UI on load
      const isLight = document.body.classList.contains('light-mode');
      updateThemeUI(isLight);

      themeToggle?.addEventListener('click', () => {
        const isLightNow = !document.body.classList.contains('light-mode');
        localStorage.setItem('theme', isLightNow ? 'light' : 'dark');
        updateThemeUI(isLightNow);
      });

      // Mouse Follower Glow
      const glow = document.getElementById('cursor-glow');
      if (glow && window.matchMedia('(hover: hover)').matches) {
        document.addEventListener('mousemove', (e) => {
          const isLight = document.body.classList.contains('light-mode');
          const color = isLight ? 'rgba(2, 132, 199, 0.08)' : 'rgba(0, 212, 255, 0.08)';
          glow.style.background = `radial-gradient(600px circle at ${e.clientX}px ${e.clientY}px, ${color}, transparent 40%)`;
          glow.style.opacity = '1';
        });
        document.addEventListener('mouseleave', () => {
          glow.style.opacity = '0';
        });
      }

      // Scroll Reveal Animation
      function initReveal() {
        const reveals = document.querySelectorAll('section, .glass-card, h1, h2, .btn-primary, .btn-secondary');
        
        reveals.forEach((el, index) => {
          if (!el.classList.contains('reveal')) {
            el.classList.add('reveal');
            if (el.classList.contains('glass-card')) {
              const delay = (index % 5) * 100;
              (el as HTMLElement).style.transitionDelay = `${delay}ms`;
            }
          }
        });

        const revealObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('active');
            }
          });
        }, {
          root: null,
          rootMargin: '0px 0px -50px 0px',
          threshold: 0.1
        });

        reveals.forEach(el => revealObserver.observe(el));
      }

      // Run on load
      document.addEventListener('DOMContentLoaded', initReveal);
      if (document.readyState === 'complete' || document.readyState === 'interactive') {
        setTimeout(initReveal, 100);
      }
    </script>
  </body>
</html>