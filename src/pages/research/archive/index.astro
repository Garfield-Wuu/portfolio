---
import Layout from '../../../layouts/Layout.astro';
import { recentNews } from '../../../data/research';

// Load archive data
import { readFileSync, existsSync } from 'fs';
const homeDir = '/home/legion';
let archivedNews = [];

try {
  const archivePath = `${homeDir}/clawd/scripts/research_exports/news_archive.json`;
  if (existsSync(archivePath)) {
    const data = JSON.parse(readFileSync(archivePath, 'utf-8'));
    archivedNews = Array.isArray(data) ? data : [];
  }
} catch (e) {
  console.error('Failed to load archive:', e);
}

// Sort by date descending
archivedNews.sort((a, b) => {
  const dateA = new Date(a.published_at || a.date || '1970-01-01');
  const dateB = new Date(b.published_at || b.date || '1970-01-01');
  return dateB - dateA;
});

// Group by month
const byMonth = {};
archivedNews.forEach(n => {
  const d = new Date(n.published_at || n.date || '1970-01-01');
  const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`;
  const label = `${d.getFullYear()}年${d.getMonth() + 1}月`;
  if (!byMonth[key]) byMonth[key] = { label, items: [] };
  byMonth[key].items.push(n);
});

const months = Object.keys(byMonth).sort().reverse();

// SEO
const archiveTitle = '研究归档 - 历史资讯 | Garfield';
const archiveDesc = `超过30天的AI/无人机/机器人领域历史资讯归档，共${archivedNews.length}条。按月份组织，方便追溯历史研究动态。`;
const archiveCanonical = 'https://www.garfield-wu.com/research/archive';
---

<Layout 
  title={archiveTitle}
  description={archiveDesc}
  ogTitle={archiveTitle}
  ogDescription={archiveDesc}
  canonical={archiveCanonical}
  page="research">
  <section class="max-w-5xl mx-auto px-6 py-16">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-3xl font-bold text-accent">📦 研究归档</h1>
        <p class="text-gray-400 mt-1">超过30天的历史资讯 · 共 {archivedNews.length} 条</p>
      </div>
      <a href="/research" class="text-sm px-3 py-1.5 rounded border border-gray-700 text-gray-400 hover:text-white hover:border-gray-500 transition-colors">
        ← 返回首页
      </a>
    </div>

    <!-- Archive Stats -->
    <div class="mb-8 p-4 bg-card/50 rounded-lg border border-gray-800">
      <p class="text-sm text-gray-400">
        📊 归档统计：{archivedNews.length} 条历史资讯，跨越 {months.length} 个月
      </p>
    </div>

    {months.length > 0 ? (
      <div class="space-y-10">
        {months.map((monthKey) => {
          const group = byMonth[monthKey];
          return (
            <div>
              <h2 class="text-lg font-bold text-white mb-4 pb-2 border-b border-gray-800">
                📅 {group.label}
                <span class="text-sm font-normal text-gray-500 ml-2">({group.items.length} 条)</span>
              </h2>
              <div class="space-y-3">
                {group.items.map((news) => (
                  <a href={news.link} target="_blank"
                    class="block p-5 bg-card rounded-xl border border-gray-800 hover:border-accent transition-all group">
                    <div class="flex items-start justify-between gap-3 mb-2">
                      <h3 class="text-base font-bold text-white group-hover:text-accent transition-colors leading-tight flex-1">
                        {news.title}
                      </h3>
                      <span class="shrink-0 text-xs px-1.5 py-0.5 rounded bg-gray-800 text-gray-500 border border-gray-700">
                        🔴 过期
                      </span>
                    </div>
                    <p class="text-gray-500 text-xs mb-2">
                      {news.source} · {news.published_at || news.date}
                      {news.archive_reason && <span class="ml-2 text-gray-600">({news.archive_reason})</span>}
                    </p>
                    <p class="text-gray-400 text-sm line-clamp-2">{news.summary}</p>
                    <p class="mt-2 text-xs text-accent group-hover:underline">阅读原文 →</p>
                  </a>
                ))}
              </div>
            </div>
          );
        })}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-gray-500 mb-2">📦 暂无历史归档</p>
        <p class="text-gray-600 text-sm">超过30天的新闻会自动归档到这里</p>
      </div>
    )}

    <!-- Footer -->
    <div class="mt-12 p-4 bg-card/50 rounded-lg border border-gray-800 text-center">
      <p class="text-gray-500 text-sm">
        📡 归档来源：每日行业简报自动归档
        <br/>
        <span class="text-gray-600 text-xs">数据每日 08:45 自动更新 · <a href="/research" class="text-accent hover:underline">返回首页</a></span>
      </p>
    </div>
  </section>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
