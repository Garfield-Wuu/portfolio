---
import Layout from '../../layouts/Layout.astro';
import { recentPapers, hotProjects, trends, recentNews, lastUpdated } from '../../data/research';

// All tags from data
const allPaperTags = [...new Set(recentPapers.flatMap(p => p.tags))];
const allGithubTags = [...new Set(hotProjects.flatMap(p => p.tags))];
const allTags = [...new Set([...allPaperTags, ...allGithubTags])].sort();
---

<Layout 
  title="研究热点 | Garfield"
  description="追踪LLM+无人机+机器人领域最新进展：最新论文、GitHub热门项目、行业资讯。数据每日自动更新。"
  ogTitle="研究热点 | Garfield"
  ogDescription="LLM+无人机+机器人领域最新研究进展，包含论文、开源项目、行业资讯。每日自动更新。"
  canonical="https://www.garfield-wu.com/research"
  page="research">
  <section class="max-w-5xl mx-auto px-6 pt-24 pb-16">
    <div class="flex items-center justify-between mb-12">
      <div>
        <h1 class="text-4xl font-bold text-white mb-2">研究热点</h1>
        <p class="text-gray-400">LLM + 无人机 + 机器人领域 · 每日更新</p>
        {lastUpdated && <p class="text-gray-500 text-xs mt-1">🕐 数据更新于 {new Date(lastUpdated).toLocaleString('zh-CN', { timeZone: 'Asia/Shanghai', year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' })}</p>}
      </div>
      <a href="/research/archive" class="text-sm px-4 py-2 rounded-lg border border-white/10 text-gray-300 hover:text-white hover:bg-white/5 transition-colors flex items-center gap-2">
        <span>📦</span> 历史归档
      </a>
    </div>

    <!-- Trends -->
    <div class="mb-16">
      <div class="flex items-center gap-4 mb-6">
        <h2 class="text-2xl font-bold text-white">🔥 研究趋势</h2>
        <div class="h-px bg-white/10 flex-1"></div>
      </div>
      <div class="grid md:grid-cols-2 gap-4">
        {trends.map(trend => (
          <div class="glass-card p-6">
            <h3 class="text-base font-semibold text-white mb-2 flex items-center gap-2">
              <span class="text-xl">{trend.icon}</span> {trend.title}
            </h3>
            <p class="text-gray-400 text-sm leading-relaxed">{trend.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Filter Bar -->
    <div class="mb-6 space-y-3">
      <!-- Type Tabs -->
      <div class="flex flex-wrap gap-2 items-center">
        <span class="text-xs text-gray-500 mr-1">类型:</span>
        <button class="filter-tab active" data-filter="all">全部</button>
        <button class="filter-tab" data-filter="papers">📚 论文</button>
        <button class="filter-tab" data-filter="github">🐙 GitHub</button>
        <button class="filter-tab" data-filter="news">📰 资讯</button>
      </div>

      <!-- Tag Filter -->
      <div class="flex flex-wrap gap-1.5 items-center">
        <span class="text-xs text-gray-500 mr-1">标签:</span>
        <button class="tag-filter active text-xs px-2 py-0.5 rounded border border-gray-700 text-gray-400 hover:border-accent hover:text-white transition-colors" data-tag="all">全部</button>
        {allTags.map(tag => (
          <button class="tag-filter text-xs px-2 py-0.5 rounded border border-gray-700 text-gray-400 hover:border-accent hover:text-white transition-colors" data-tag={tag}>{tag}</button>
        ))}
      </div>

      <!-- Search + Sort -->
      <div class="flex gap-3 items-center">
        <div class="relative flex-1 max-w-md">
          <input type="text" id="search-input" placeholder="搜索标题、摘要、关键词..." 
            class="w-full px-3 py-2 pr-8 bg-card border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:border-accent focus:outline-none">
          <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-500 text-xs">🔍</span>
        </div>
        <select id="sort-select" class="px-3 py-2 bg-card border border-gray-700 rounded-lg text-sm text-gray-300 focus:border-accent focus:outline-none">
          <option value="date-desc">🕐 最新优先</option>
          <option value="date-asc">🕐 最旧优先</option>
          <option value="stars">⭐ Stars</option>
          <option value="importance">⭐ 重要性</option>
        </select>
      </div>

      <!-- Results count -->
      <div class="text-xs text-gray-500">
        <span id="results-count">0</span> 条结果
      </div>
    </div>

    <!-- Content Sections -->
    <div id="content-sections">
      <!-- News Section -->
      <div class="content-section" data-type="news">
        <h2 class="text-xl font-bold mb-4 text-accent flex items-center gap-2">
          📰 最新资讯
          <span class="text-xs font-normal text-gray-500">({recentNews.length})</span>
        </h2>
        <div class="news-list space-y-3 mb-10">
          {recentNews.map((news, idx) => (
            <a href={news.link} target="_blank" rel="noopener noreferrer"
              class="content-card block glass-card p-6 group"
              data-title={news.title.toLowerCase()}
              data-tags="news"
              data-date={news.date}
              data-summary={news.summary.toLowerCase()}>
              <div class="flex items-start justify-between gap-3 mb-2">
                <h3 class="text-base font-bold text-white group-hover:text-accent transition-colors leading-tight">
                  {news.title}
                </h3>
                {news.freshness === 'fresh' && (
                  <span class="shrink-0 text-xs px-1.5 py-0.5 rounded bg-green-900/40 text-green-400 border border-green-800">🟢</span>
                )}
                {news.freshness === 'aging' && (
                  <span class="shrink-0 text-xs px-1.5 py-0.5 rounded bg-yellow-900/40 text-yellow-400 border border-yellow-800">🟡</span>
                )}
              </div>
              <p class="text-gray-500 text-xs mb-2">{news.source} · {news.date}</p>
              <p class="text-gray-400 text-sm line-clamp-2">{news.summary}</p>
              <p class="mt-2 text-xs text-accent group-hover:underline">阅读原文 →</p>
            </a>
          ))}
        </div>
      </div>

      <!-- Papers Section -->
      <div class="content-section" data-type="papers">
        <h2 class="text-xl font-bold mb-4 text-accent flex items-center gap-2">
          📚 最新论文
          <span class="text-xs font-normal text-gray-500">({recentPapers.length})</span>
        </h2>
        <div class="papers-list space-y-3 mb-10">
          {recentPapers.map((paper, idx) => (
            <a href={paper.link} target="_blank" rel="noopener noreferrer"
              class="content-card block glass-card p-6 group"
              data-title={paper.title.toLowerCase()}
              data-tags={JSON.stringify(paper.tags).toLowerCase()}
              data-date={paper.date}
              data-summary={paper.summary.toLowerCase()}
              data-importance={paper.importance}>
              <div class="flex items-start justify-between gap-3 mb-2">
                <div class="flex-1 min-w-0">
                  <h3 class="text-base font-bold text-white group-hover:text-accent transition-colors leading-tight mb-1">
                    {paper.title}
                  </h3>
                  <p class="text-gray-500 text-xs">{paper.authors || paper.venue} · {paper.date}</p>
                </div>
                {paper.importance === 'high' && (
                  <span class="shrink-0 text-xs px-2 py-1 rounded bg-red-900/40 text-red-400 border border-red-800">⭐ 高优先级</span>
                )}
              </div>
              <p class="text-gray-400 text-sm mb-3 line-clamp-2">{paper.summary}</p>
              <div class="flex flex-wrap gap-1.5 mb-2">
                {paper.tags.map(tag => (
                  <span class="text-xs px-1.5 py-0.5 rounded bg-dark text-gray-400 border border-gray-700">{tag}</span>
                ))}
              </div>
              <p class="text-xs text-accent group-hover:underline">arXiv 原文 →</p>
            </a>
          ))}
        </div>
      </div>

      <!-- GitHub Section -->
      <div class="content-section" data-type="github">
        <h2 class="text-xl font-bold mb-4 text-accent flex items-center gap-2">
          ⭐ GitHub 热门项目
          <span class="text-xs font-normal text-gray-500">({hotProjects.length})</span>
        </h2>
        <div class="github-list grid md:grid-cols-2 gap-3 mb-10">
          {hotProjects.map((project, idx) => (
            <a href={project.link} target="_blank" rel="noopener noreferrer"
              class="content-card block glass-card p-6 group"
              data-title={project.name.toLowerCase()}
              data-tags={JSON.stringify(project.tags).toLowerCase()}
              data-date=""
              data-summary={project.description.toLowerCase()}
              data-stars={project.stars}
              data-stars-num={parseFloat(project.stars) || 0}>
              <div class="flex items-start justify-between gap-3 mb-2">
                <h3 class="text-base font-bold text-white group-hover:text-accent transition-colors">{project.name}</h3>
                <span class="shrink-0 text-sm px-2 py-1 rounded bg-yellow-900/30 text-yellow-400 border border-yellow-800">★ {project.stars}</span>
              </div>
              <p class="text-gray-400 text-sm mb-3 line-clamp-2">{project.description}</p>
              <div class="flex items-center justify-between">
                <div class="flex flex-wrap gap-1">
                  {project.tags.slice(0, 4).map(tag => (
                    <span class="text-xs px-1.5 py-0.5 rounded bg-dark text-gray-400 border border-gray-700">{tag}</span>
                  ))}
                </div>
                <span class="text-xs text-gray-500">{project.language}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Empty State -->
    <div id="empty-state" class="hidden text-center py-16">
      <p class="text-gray-500 mb-2">🔍 没有找到匹配的结果</p>
      <p class="text-gray-600 text-sm">尝试调整筛选条件或关键词</p>
    </div>

    <!-- Data Source -->
    <div class="mt-12 glass-card p-6 text-center">
      <p class="text-gray-400 text-sm">
        📡 数据来源：
        <a href="https://arxiv.org" target="_blank" rel="noopener noreferrer" class="text-accent hover:text-white transition-colors">arXiv</a> ·
        <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="text-accent hover:text-white transition-colors">GitHub</a> ·
        <a href="/research/archive" class="text-accent hover:text-white transition-colors">📦 历史归档</a>
        <br/>
        <span class="text-gray-500 text-xs mt-2 inline-block">研究方向：LLM + 无人机 + 具身智能 · 每日 08:45 自动更新</span>
      </p>
    </div>
  </section>
</Layout>

<style>
  .filter-tab {
    padding: 0.375rem 0.75rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    border: 1px solid rgb(55 55 55);
    color: rgb(156 163 175);
    transition: all 0.2s;
    cursor: pointer;
    background: transparent;
  }
  .filter-tab:hover {
    border-color: rgb(75 75 75);
    color: white;
  }
  .filter-tab.active {
    background: rgba(0 212 255, 0.2);
    border-color: #00d4ff;
    color: #00d4ff;
  }
  
  .tag-filter {
    transition: all 0.2s;
    cursor: pointer;
    padding: 0.125rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.75rem;
    border: 1px solid rgb(55 55 55);
    color: rgb(156 163 175);
    background: transparent;
  }
  .tag-filter:hover {
    border-color: #00d4ff;
    color: white;
  }
  .tag-filter.active {
    background: rgba(0 212 255, 0.2);
    border-color: #00d4ff;
    color: white;
  }

  .content-section.hidden { display: none; }
  .content-card.hidden { display: none; }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  /* Search highlight */
  .search-highlight {
    background: rgba(0 212 255, 0.3);
    color: #00d4ff;
    padding: 0 2px;
    border-radius: 2px;
    font-weight: 500;
  }
  
  .search-empty-hint {
    color: rgb(107 114 128);
    font-size: 0.75rem;
    margin-top: 0.25rem;
  }
</style>

<script>
  // Filter & Search Logic
  const filterTabs = document.querySelectorAll('.filter-tab');
  const tagFilters = document.querySelectorAll('.tag-filter');
  const searchInput = document.getElementById('search-input');
  const sortSelect = document.getElementById('sort-select');
  const resultsCount = document.getElementById('results-count');
  const contentSections = document.querySelectorAll('.content-section');
  const allCards = document.querySelectorAll('.content-card');
  const emptyState = document.getElementById('empty-state');

  let currentType = 'all';
  let currentTag = 'all';
  let searchQuery = '';
  let currentSort = 'date-desc';

  function normalizeStr(s) {
    return String(s || '').toLowerCase().replace(/[^\w\s]/g, ' ');
  }

  function parseStars(s) {
    const num = parseFloat(s);
    if (s.includes('k')) return num * 1000;
    return num || 0;
  }

  // Highlight search terms in text nodes
  function highlightText(node, query) {
    if (!query || query.length < 2) return;
    
    const walker = document.createTreeWalker(node, NodeFilter.SHOW_TEXT, null, false);
    const nodesToProcess = [];
    while (walker.nextNode()) {
      const text = walker.currentNode.nodeValue;
      if (text && text.trim() && !walker.currentNode.parentElement?.closest('.content-card')) {
        // Only process visible text in card titles, summaries, and tags
        const parent = walker.currentNode.parentElement;
        if (parent && (parent.classList.contains('text-base') || 
            parent.classList.contains('text-sm') || 
            parent.classList.contains('text-xs'))) {
          nodesToProcess.push(walker.currentNode);
        }
      }
    }
    
    nodesToProcess.forEach(textNode => {
      const text = textNode.nodeValue;
      const normQuery = normalizeStr(query);
      const words = normQuery.split(/\s+/).filter(w => w.length >= 2);
      
      let modified = text;
      words.forEach(word => {
        const regex = new RegExp(`(${word.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
        modified = modified.replace(regex, '<mark class="search-highlight">$1</mark>');
      });
      
      if (modified !== text) {
        const span = document.createElement('span');
        span.innerHTML = modified;
        textNode.parentNode.replaceChild(span, textNode);
        // Unwrap the <span> but keep the <mark>
        Array.from(span.childNodes).forEach(child => {
          textNode.parentNode.insertBefore(child, textNode);
        });
        textNode.parentNode.removeChild(textNode);
      }
    });
  }

  // Remove all highlights
  function removeHighlights() {
    document.querySelectorAll('mark.search-highlight').forEach(mark => {
      const parent = mark.parentNode;
      parent.replaceChild(document.createTextNode(mark.textContent), mark);
      parent.normalize();
    });
  }

  function applyFilters() {
    let visibleCount = 0;

    // Remove old highlights first
    removeHighlights();

    // Show/hide sections by type
    contentSections.forEach(section => {
      const type = section.dataset.type;
      const sectionVisible = currentType === 'all' || currentType === type;
      section.classList.toggle('hidden', !sectionVisible);
    });

    // Filter cards
    allCards.forEach(card => {
      const cardType = card.dataset.tags?.includes('news') ? 'news' : 
                       card.dataset.tags?.includes('[') ? 'github' : 'papers';
      const cardTags = card.dataset.tags || '';
      const cardTitle = card.dataset.title || '';
      const cardSummary = card.dataset.summary || '';
      
      // Type filter
      const typeMatch = currentType === 'all' || cardType === currentType;
      
      // Tag filter
      const tagMatch = currentTag === 'all' || cardTags.includes(currentTag.toLowerCase());
      
      // Search filter
      const searchNorm = normalizeStr(searchQuery);
      const searchMatch = !searchQuery || 
        cardTitle.includes(searchNorm) || 
        cardSummary.includes(searchNorm) ||
        cardTags.includes(searchNorm);

      const visible = typeMatch && tagMatch && searchMatch;
      card.classList.toggle('hidden', !visible);
      if (visible) {
        visibleCount++;
        // Apply highlight to visible cards
        if (searchQuery && searchQuery.length >= 2) {
          highlightText(card, searchQuery);
        }
      }
    });

    // Sort
    applySorting();

    // Update count
    resultsCount.textContent = visibleCount;
    emptyState.classList.toggle('hidden', visibleCount > 0);
  }

  function applySorting() {
    // Collect visible cards by section
    contentSections.forEach(section => {
      if (section.classList.contains('hidden')) return;
      
      const sectionType = section.dataset.type;
      const cards = section.querySelectorAll('.content-card:not(.hidden)');
      const containers = {
        'news': section.querySelector('.news-list'),
        'papers': section.querySelector('.papers-list'),
        'github': section.querySelector('.github-list')
      };
      const container = containers[sectionType];
      if (!container) return;

      const sorted = Array.from(cards).sort((a, b) => {
        if (sectionType === 'github') {
          const starsA = parseStars(a.dataset.stars || '0');
          const starsB = parseStars(b.dataset.stars || '0');
          if (currentSort === 'stars') return starsB - starsA;
        }
        
        if (sectionType === 'papers') {
          const impA = a.dataset.importance === 'high' ? 1 : 0;
          const impB = b.dataset.importance === 'high' ? 1 : 0;
          if (currentSort === 'importance') return impB - impA;
        }

        const dateA = new Date(a.dataset.date || '1970-01-01');
        const dateB = new Date(b.dataset.date || '1970-01-01');
        return currentSort === 'date-asc' ? dateA - dateB : dateB - dateA;
      });

      sorted.forEach(card => container.appendChild(card));
    });
  }

  // Event listeners
  filterTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      filterTabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      currentType = tab.dataset.filter || 'all';
      applyFilters();
    });
  });

  tagFilters.forEach(btn => {
    btn.addEventListener('click', () => {
      tagFilters.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentTag = btn.dataset.tag || 'all';
      applyFilters();
    });
  });

  let searchTimeout;
  searchInput?.addEventListener('input', (e) => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
      searchQuery = normalizeStr(e.target.value);
      applyFilters();
    }, 200);
  });

  sortSelect?.addEventListener('change', (e) => {
    currentSort = e.target.value;
    applyFilters();
  });

  // Initial count
  resultsCount.textContent = allCards.length;
</script>
