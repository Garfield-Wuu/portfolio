---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects';

const statusLabels: Record<string, string> = {
  active: '进行中',
  completed: '已完成',
  research: '研究型',
};

const statusColors: Record<string, string> = {
  active: 'bg-green-500/10 text-green-400 border border-green-500/20',
  completed: 'bg-blue-500/10 text-blue-400 border border-blue-500/20',
  research: 'bg-purple-500/10 text-purple-400 border border-purple-500/20',
};
---

<Layout title="项目" page="projects">
  <section class="max-w-5xl mx-auto px-6 pt-24 pb-16">
    <div class="mb-12">
      <h1 class="text-4xl font-bold mb-4 text-white">项目作品</h1>
      <p class="text-lg text-gray-400 max-w-2xl">持续更新中，涵盖无人机、机器人、全栈开发等领域。包含个人研究、开源贡献及工程实践。</p>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      {projects.map(project => (
        <div class="glass-card p-8 group flex flex-col h-full">
          <div class="flex items-start justify-between mb-4">
            <h3 class="text-2xl font-bold text-white group-hover:text-accent transition-colors">
              {project.title}
            </h3>
            <span class={`shrink-0 text-xs px-2.5 py-1 rounded-full ${statusColors[project.status]}`}>
              {statusLabels[project.status]}
            </span>
          </div>
          <p class="text-gray-400 text-base leading-relaxed mb-6 flex-1">
            {project.desc}
          </p>
          <div class="flex flex-wrap gap-2 mb-6">
            {project.tags.map(tag => (
              <span class="text-xs px-2.5 py-1 bg-white/5 rounded text-gray-400 border border-white/5 group-hover:border-white/10 transition-colors">
                {tag}
              </span>
            ))}
          </div>
          <div class="flex items-center gap-4 mt-auto pt-4 border-t border-white/5">
            {project.link !== '#' && (
              <a href={project.link} target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-accent hover:text-white transition-colors flex items-center gap-1">
                访问项目 ↗
              </a>
            )}
            {project.github && (
              <a href={project.github} target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-gray-400 hover:text-white transition-colors flex items-center gap-1">
                <span class="text-lg">🐙</span> GitHub
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>
