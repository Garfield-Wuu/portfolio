---
import Layout from '../layouts/Layout.astro';
import { profile } from '../data/profile';
---

<Layout title="关于" page="about">
  <section class="max-w-5xl mx-auto px-6 py-16">
    <!-- About -->
    <div class="mb-16">
      <h1 class="text-3xl font-bold mb-6 text-accent">关于我</h1>
      <div class="flex flex-col md:flex-row gap-8">
        <img 
          src={profile.avatar} 
          alt={profile.name} 
          class="w-40 h-40 rounded-full object-cover shrink-0"
          onerror={`this.onerror=null; this.textContent='${profile.avatarFallback}'`}
        />
        <div>
          <p class="text-gray-300 mb-4">
            {profile.about.school} {profile.degree}，现居{profile.about.location}。
          </p>
          <p class="text-gray-400 mb-4">
            研究方向为 <span class="text-accent">{profile.about.research}</span>，
            探索如何利用自然语言控制无人机执行复杂任务，构建人机交互新范式。
          </p>
          <p class="text-gray-400 mb-4">
            热爱开源，活跃于 PX4/Prometheus 社区。业余时间喜欢折腾各种技术栈，
            从嵌入式开发到全栈应用都有涉猎。
          </p>
          <div class="flex flex-wrap gap-2">
            {profile.about.interests.map(interest => (
              <span class="text-sm text-gray-500">#{interest}</span>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Research -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold mb-6 text-accent">研究方向</h2>
      <div class="grid md:grid-cols-2 gap-4">
        {profile.researchAreas.map(area => (
          <div class="p-6 bg-card rounded-xl border border-gray-800 hover:border-accent transition-colors">
            <h3 class="text-lg font-bold text-white mb-2">{area.icon} {area.title}</h3>
            <p class="text-gray-400 text-sm">{area.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Skills -->
    <div>
      <h2 class="text-2xl font-bold mb-6 text-accent">技能树</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {profile.skillGroups.map(group => (
          <div class="p-6 bg-card rounded-xl border border-gray-800">
            <h3 class="text-lg font-bold text-white mb-4">{group.name}</h3>
            <div class="flex flex-wrap gap-2">
              {group.skills.map(skill => (
                <span class="px-3 py-1 bg-dark rounded text-gray-300 text-sm border border-gray-800 hover:border-accent transition-colors">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
