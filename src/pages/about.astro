---
import Layout from '../layouts/Layout.astro';
import { profile } from '../data/profile';
---

<Layout title="关于" page="about">
  <section class="max-w-5xl mx-auto px-6 pt-24 pb-16">
    <!-- About -->
    <div class="mb-20">
      <h1 class="text-4xl font-bold mb-10 text-white">关于我</h1>
      <div class="glass-card p-8 md:p-10 flex flex-col md:flex-row gap-10 items-center md:items-start">
        <div class="relative shrink-0">
          <div class="absolute inset-0 bg-gradient-to-tr from-accent to-purple rounded-full blur-2xl opacity-40"></div>
          <img 
            src={profile.avatar} 
            alt={profile.name} 
            class="relative w-40 h-40 rounded-full object-cover border-2 border-white/10 z-10"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
          />
          <div class="hidden relative z-10 w-40 h-40 rounded-full items-center justify-center text-6xl font-bold text-gray-600 bg-card border-2 border-white/10">
            {profile.avatarFallback}
          </div>
        </div>
        <div class="flex-1 text-center md:text-left">
          <p class="text-xl text-white mb-6 leading-relaxed">
            {profile.about.school} <span class="text-accent">{profile.degree}</span>，现居{profile.about.location}。
          </p>
          <p class="text-gray-400 text-lg mb-6 leading-relaxed">
            研究方向为 <span class="text-white font-medium">{profile.about.research}</span>，
            探索如何利用自然语言控制无人机执行复杂任务，构建人机交互新范式。
          </p>
          <p class="text-gray-400 text-lg mb-8 leading-relaxed">
            热爱开源，活跃于 PX4/Prometheus 社区。业余时间喜欢折腾各种技术栈，
            从嵌入式开发到全栈应用都有涉猎。
          </p>
          <div class="flex flex-wrap justify-center md:justify-start gap-3">
            {profile.about.interests.map(interest => (
              <span class="px-4 py-1.5 bg-accent/10 text-accent border border-accent/20 rounded-full text-sm font-medium">
                #{interest}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Research -->
    <div class="mb-20">
      <div class="flex items-center gap-4 mb-10">
        <h2 class="text-3xl font-bold text-white">研究方向</h2>
        <div class="h-px bg-white/10 flex-1"></div>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {profile.researchAreas.map(area => (
          <div class="glass-card p-8 group">
            <div class="flex items-center gap-4 mb-4">
              <span class="text-4xl bg-white/5 p-3 rounded-xl border border-white/5 group-hover:border-accent/30 transition-colors">{area.icon}</span>
              <h3 class="text-xl font-bold text-white group-hover:text-accent transition-colors">{area.title}</h3>
            </div>
            <p class="text-gray-400 leading-relaxed">{area.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Skills -->
    <div>
      <div class="flex items-center gap-4 mb-10">
        <h2 class="text-3xl font-bold text-white">技能树</h2>
        <div class="h-px bg-white/10 flex-1"></div>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        {profile.skillGroups.map(group => (
          <div class="glass-card p-8">
            <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
              <span class="w-2 h-6 bg-gradient-to-b from-accent to-purple rounded-full"></span>
              {group.name}
            </h3>
            <div class="flex flex-wrap gap-3">
              {group.skills.map(skill => (
                <span class="px-4 py-2 bg-dark/50 rounded-lg text-gray-300 text-sm border border-white/5 hover:border-accent hover:text-white transition-colors cursor-default">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
