---
import Layout from '../layouts/Layout.astro';
import { profile } from '../data/profile';
import { projects } from '../data/projects';

// 取前3个项目展示在首页
const featuredProjects = projects.slice(0, 3);
---

<Layout title="首页" description={profile.bio} page="home">
  <!-- Hero Section -->
  <section class="max-w-5xl mx-auto px-6 py-24">
    <div class="flex flex-col md:flex-row items-center gap-12">
      <img 
        src={profile.avatar} 
        alt={profile.name} 
        class="w-32 h-32 rounded-full object-cover shrink-0"
        onerror={`this.onerror=null; this.textContent='${profile.avatarFallback}'`}
      />
      <div class="text-center md:text-left">
        <h1 class="text-4xl font-bold mb-4">你好，我是 <span class="text-accent">{profile.name}</span></h1>
        <p class="text-xl text-gray-400 mb-6">
          {profile.title}
        </p>
        <p class="text-gray-500 max-w-xl">
          {profile.bio}
        </p>
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section class="max-w-5xl mx-auto px-6 py-12">
    <h2 class="text-2xl font-bold mb-6 text-accent">技术栈</h2>
    <div class="flex flex-wrap gap-3">
      {profile.skillGroups.flatMap(g => g.skills).map(skill => (
        <span class="px-4 py-2 bg-card rounded-lg text-gray-300 border border-gray-800 hover:border-accent transition-colors">
          {skill}
        </span>
      ))}
    </div>
  </section>

  <!-- Recent Projects -->
  <section class="max-w-5xl mx-auto px-6 py-12">
    <h2 class="text-2xl font-bold mb-6 text-accent">最新项目</h2>
    <div class="grid md:grid-cols-3 gap-6">
      {featuredProjects.map(project => (
        <a href={project.link} target={project.link.startsWith('http') ? '_blank' : '_self'} 
           class="block p-6 bg-card rounded-xl border border-gray-800 hover:border-accent transition-all hover:scale-[1.02]">
          <h3 class="text-xl font-bold mb-2 text-white">{project.title}</h3>
          <p class="text-gray-400 text-sm mb-4">{project.desc}</p>
          <div class="flex flex-wrap gap-2">
            {project.tags.slice(0, 3).map(tag => (
              <span class="text-xs px-2 py-1 bg-dark rounded text-gray-500">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
    <div class="mt-8 text-center">
      <a href="/projects" class="text-accent hover:underline">查看全部项目 →</a>
    </div>
  </section>

  <!-- Social Links -->
  <section class="max-w-5xl mx-auto px-6 py-12">
    <h2 class="text-2xl font-bold mb-6 text-accent">社交链接</h2>
    <div class="flex flex-wrap gap-4">
      {profile.social.github && (
        <a href={profile.social.github} target="_blank" class="flex items-center gap-2 px-4 py-3 bg-card rounded-lg border border-gray-800 hover:border-accent transition-colors">
          <span>🐙</span> <span>GitHub</span>
        </a>
      )}
      {profile.social.bilibili && (
        <a href={profile.social.bilibili} target="_blank" class="flex items-center gap-2 px-4 py-3 bg-card rounded-lg border border-gray-800 hover:border-accent transition-colors">
          <span>📺</span> <span>B站</span>
        </a>
      )}
    </div>
  </section>
</Layout>
