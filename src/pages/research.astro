---
import Layout from '../layouts/Layout.astro';
import { recentPapers, hotProjects, trends, recentNews } from '../data/research';
---

<Layout title="研究热点" page="research">
  <section class="max-w-5xl mx-auto px-6 py-16">
    <h1 class="text-3xl font-bold mb-4 text-accent">研究热点</h1>
    <p class="text-gray-400 mb-12">追踪 LLM + 无人机 + 机器人领域最新进展</p>

    <!-- Trends -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold mb-6 text-accent">🔥 研究趋势</h2>
      <div class="grid md:grid-cols-2 gap-4">
        {trends.map(trend => (
          <div class="p-6 bg-card rounded-xl border border-gray-800 hover:border-accent transition-colors">
            <h3 class="text-lg font-bold text-white mb-2">{trend.icon} {trend.title}</h3>
            <p class="text-gray-400 text-sm">{trend.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- News -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold mb-6 text-accent">📰 最新资讯</h2>
      <div class="space-y-4">
        {recentNews.length > 0 ? (
          recentNews.map(news => (
            <a href={news.link} target="_blank" class="block p-6 bg-card rounded-xl border border-gray-800 hover:border-accent transition-all group">
              <div class="flex items-start justify-between mb-2">
                <h3 class="text-lg font-bold text-white group-hover:text-accent transition-colors flex-1 pr-4">
                  {news.title}
                </h3>
              </div>
              <p class="text-gray-500 text-xs mb-2">{news.source} · {news.date}</p>
              <p class="text-gray-400 text-sm mb-3">{news.summary}</p>
              <span class="text-xs text-accent hover:underline">阅读原文 →</span>
            </a>
          ))
        ) : (
          <div class="p-6 bg-card rounded-xl border border-gray-800 text-center">
            <p class="text-gray-500">暂无最新资讯</p>
          </div>
        )}
      </div>
    </div>

    <!-- Latest Papers -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold mb-6 text-accent">📚 最新论文</h2>
      <div class="space-y-4">
        {recentPapers.map(paper => (
          <a href={paper.link} target="_blank" class="block p-6 bg-card rounded-xl border border-gray-800 hover:border-accent transition-all group">
            <div class="flex items-start justify-between mb-2">
              <div class="flex-1">
                <h3 class="text-lg font-bold text-white group-hover:text-accent transition-colors mb-1">
                  {paper.title}
                </h3>
                <p class="text-gray-500 text-xs">{paper.authors} · {paper.venue}</p>
              </div>
              {paper.importance === 'high' && (
                <span class="shrink-0 text-xs px-2 py-1 rounded bg-red-900/50 text-red-400 border border-red-800">⭐ 高优先级</span>
              )}
            </div>
            <p class="text-gray-400 text-sm mb-4">{paper.summary}</p>
            <div class="flex flex-wrap gap-2">
              {paper.tags.map(tag => (
                <span class="text-xs px-2 py-1 bg-dark rounded text-gray-500 border border-gray-800">{tag}</span>
              ))}
            </div>
            <div class="mt-3 pt-3 border-t border-gray-800">
              <span class="text-xs text-accent hover:underline">arXiv 原文 →</span>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- GitHub Projects -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold mb-6 text-accent">⭐ GitHub 热门项目</h2>
      <div class="grid md:grid-cols-2 gap-4">
        {hotProjects.map(project => (
          <a href={project.link} target="_blank" class="block p-6 bg-card rounded-xl border border-gray-800 hover:border-accent transition-all group">
            <div class="flex items-start justify-between mb-2">
              <h3 class="text-xl font-bold text-white group-hover:text-accent transition-colors">{project.name}</h3>
              <span class="shrink-0 text-sm px-2 py-1 rounded bg-yellow-900/30 text-yellow-400 border border-yellow-800">★ {project.stars}</span>
            </div>
            <p class="text-gray-400 text-sm mb-4">{project.description}</p>
            <div class="flex items-center justify-between">
              <div class="flex flex-wrap gap-2">
                {project.tags.map(tag => (
                  <span class="text-xs px-2 py-1 bg-dark rounded text-gray-500 border border-gray-800">{tag}</span>
                ))}
              </div>
              <span class="text-xs text-gray-500">{project.language}</span>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- Data Source -->
    <div class="mt-12 p-4 bg-card/50 rounded-lg border border-gray-800 text-center">
      <p class="text-gray-500 text-sm">
        📡 数据来源：
        <a href="https://arxiv.org" target="_blank" class="text-accent hover:underline">arXiv</a> ·
        <a href="https://github.com" target="_blank" class="text-accent hover:underline">GitHub</a> ·
        <a href="https://papers.cool" target="_blank" class="text-accent hover:underline">Papers with Code</a>
        <br/>
        <span class="text-gray-600">研究方向：LLM + 无人机 + 具身智能 · 数据每日更新</span>
      </p>
    </div>
  </section>
</Layout>
